<%- include('partials/header') %>

<%
  function fmtDate(d) {
    if (!d) return '';
    return new Date(d).toISOString().slice(0, 10);
  }
%>

<div class="max-w-xl mx-auto">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-xl font-semibold text-slate-800">기록 수정</h1>
    <a href="/<%= content._id %>" class="btn-ghost py-1.5">← 취소</a>
  </div>

  <form method="POST" action="/<%= content._id %>/edit" class="bg-white border border-slate-200 rounded-2xl p-6 space-y-4">
    <div>
      <label class="label">제목 <span class="text-red-500">*</span></label>
      <input type="text" name="title" class="field" required value="<%= content.title %>">
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="label">종류 <span class="text-red-500">*</span></label>
        <select name="type" class="field" required>
          <% ['영화', '드라마', '애니메이션', '소설'].forEach(t => { %>
            <option value="<%= t %>" <%= content.type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">장르 <span class="text-red-500">*</span></label>
        <input type="text" name="genre" class="field" required value="<%= content.genre %>">
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="label">상태 <span class="text-red-500">*</span></label>
        <select name="status" class="field" required>
          <% ['봄', '보는중', '보고싶음'].forEach(s => { %>
            <option value="<%= s %>" <%= content.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">평점</label>
        <select name="rating" class="field">
          <option value="">없음</option>
          <% for (let i = 1; i <= 5; i++) { %>
            <option value="<%= i %>" <%= content.rating === i ? 'selected' : '' %>><%= '★'.repeat(i) %> <%= i %>점</option>
          <% } %>
        </select>
      </div>
    </div>

    <div>
      <label class="label">감상일</label>
      <input type="date" name="watchedAt" class="field" value="<%= fmtDate(content.watchedAt) %>">
    </div>

    <div>
      <label class="label">감상평</label>
      <textarea name="memo" class="field" rows="3"><%= content.memo || '' %></textarea>
    </div>

    <div class="flex gap-2 pt-2">
      <button type="submit" class="btn-primary">수정 저장</button>
      <a href="/<%= content._id %>" class="btn-ghost">취소</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
