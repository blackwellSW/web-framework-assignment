<%- include('partials/header') %>

<div class="max-w-xl mx-auto">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-xl font-semibold text-slate-800">새 콘텐츠 추가</h1>
    <a href="/" class="btn-ghost py-1.5">← 목록</a>
  </div>

  <form method="POST" action="/add" class="bg-white border border-slate-200 rounded-2xl p-6 space-y-4">
    <div>
      <label class="label">제목 <span class="text-red-500">*</span></label>
      <input type="text" name="title" class="field" required placeholder="제목 입력">
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="label">종류 <span class="text-red-500">*</span></label>
        <select name="type" class="field" required>
          <option value="">선택</option>
          <option value="영화">영화</option>
          <option value="드라마">드라마</option>
          <option value="애니메이션">애니메이션</option>
          <option value="소설">소설</option>
        </select>
      </div>
      <div>
        <label class="label">장르 <span class="text-red-500">*</span></label>
        <input type="text" name="genre" class="field" required placeholder="액션, 로맨스, SF...">
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="label">상태 <span class="text-red-500">*</span></label>
        <select name="status" class="field" required>
          <option value="">선택</option>
          <option value="봄">봄</option>
          <option value="보는중">보는중</option>
          <option value="보고싶음">보고싶음</option>
        </select>
      </div>
      <div>
        <label class="label">평점</label>
        <select name="rating" class="field">
          <option value="">없음</option>
          <option value="1">★ 1점</option>
          <option value="2">★★ 2점</option>
          <option value="3">★★★ 3점</option>
          <option value="4">★★★★ 4점</option>
          <option value="5">★★★★★ 5점</option>
        </select>
      </div>
    </div>

    <div>
      <label class="label">감상일</label>
      <input type="date" name="watchedAt" class="field">
    </div>

    <div>
      <label class="label">감상평</label>
      <textarea name="memo" class="field" rows="3" placeholder="한 줄 감상평을 남겨보세요"></textarea>
    </div>

    <div class="flex gap-2 pt-2">
      <button type="submit" class="btn-primary">저장</button>
      <a href="/" class="btn-ghost">취소</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
