<%- include('partials/header') %>

<div class="flex items-center justify-between mb-5">
  <h1 class="text-xl font-semibold text-slate-800">감상 통계</h1>
  <a href="/" class="btn-ghost py-1.5">← 목록</a>
</div>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
  <div class="bg-white border border-slate-200 rounded-xl px-4 py-4 text-center">
    <div class="text-3xl font-semibold text-slate-800"><%= total %></div>
    <div class="text-sm text-slate-500 mt-1">전체</div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl px-4 py-4 text-center">
    <div class="text-3xl font-semibold text-emerald-600"><%= watched %></div>
    <div class="text-sm text-slate-500 mt-1">봄</div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl px-4 py-4 text-center">
    <div class="text-3xl font-semibold text-amber-500"><%= watching %></div>
    <div class="text-sm text-slate-500 mt-1">보는중</div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl px-4 py-4 text-center">
    <div class="text-3xl font-semibold text-slate-500"><%= wishlist %></div>
    <div class="text-sm text-slate-500 mt-1">보고싶음</div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <div class="bg-white border border-slate-200 rounded-2xl p-6 text-center flex flex-col justify-center">
    <div class="text-sm text-slate-500 mb-1">평균 평점</div>
    <div class="text-4xl font-semibold text-amber-500"><%= avgRating %></div>
    <div class="text-sm text-slate-400 mt-1">/ 5점</div>
  </div>

  <div class="bg-white border border-slate-200 rounded-2xl p-6 md:col-span-2">
    <h2 class="font-medium text-slate-800 mb-4">장르별 기록 수</h2>
    <% if (byGenre.length === 0) { %>
      <p class="text-slate-400">데이터 없음</p>
    <% } else { %>
      <% const max = byGenre[0].count; %>
      <div class="space-y-3">
        <% byGenre.forEach(g => { %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-slate-700"><%= g._id %></span>
              <span class="text-slate-400"><%= g.count %></span>
            </div>
            <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
              <div class="h-full rounded-full bg-brand-500" style="width: <%= Math.round((g.count / max) * 100) %>%"></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
