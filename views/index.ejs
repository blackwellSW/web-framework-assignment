<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">전체 기록 <span class="badge bg-secondary"><%= contents.length %></span></h4>
</div>

<!-- 필터 -->
<form method="GET" action="/" class="row g-2 mb-4">
  <div class="col-auto">
    <select name="status" class="form-select form-select-sm">
      <option value="">전체 상태</option>
      <option value="봄" <%= selectedStatus === '봄' ? 'selected' : '' %>>봄</option>
      <option value="보는중" <%= selectedStatus === '보는중' ? 'selected' : '' %>>보는중</option>
      <option value="보고싶음" <%= selectedStatus === '보고싶음' ? 'selected' : '' %>>보고싶음</option>
    </select>
  </div>
  <div class="col-auto">
    <select name="genre" class="form-select form-select-sm">
      <option value="">전체 장르</option>
      <% genres.forEach(g => { %>
        <option value="<%= g %>" <%= selectedGenre === g ? 'selected' : '' %>><%= g %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-outline-secondary btn-sm">필터 적용</button>
    <a href="/" class="btn btn-outline-secondary btn-sm">초기화</a>
  </div>
</form>

<!-- 카드 목록 -->
<% if (contents.length === 0) { %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-camera-reels fs-1"></i>
    <p class="mt-2">기록된 콘텐츠가 없습니다. 추가해보세요!</p>
    <a href="/add" class="btn btn-primary">+ 첫 기록 추가</a>
  </div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-3 g-3">
    <% contents.forEach(c => { %>
      <div class="col">
        <a href="/<%= c._id %>" class="text-decoration-none">
          <div class="card h-100 shadow-sm card-hover">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <span class="badge bg-<%= c.type === '영화' ? 'primary' : 'success' %> mb-2"><%= c.type %></span>
                <span class="badge status-badge status-<%= c.status %>"><%= c.status %></span>
              </div>
              <h6 class="card-title fw-bold text-dark"><%= c.title %></h6>
              <p class="card-text text-muted small"><%= c.genre %></p>
              <% if (c.rating) { %>
                <div class="stars">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <i class="bi bi-star<%= i <= c.rating ? '-fill text-warning' : ' text-secondary' %>"></i>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
